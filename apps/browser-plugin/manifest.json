{
  "manifest_version": 3,
  "name": "LocalCraft.io",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://localcraft-io.onrender.com/*"],
  "action": {
    "default_title": "Read JD",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
